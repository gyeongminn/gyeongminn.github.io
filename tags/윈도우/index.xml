&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;k&#34;&gt;if&lt;/span&gt; &amp;#39;&lt;span class=&#34;nv&#34;&gt;%1&lt;/span&gt;&amp;#39;&lt;span class=&#34;o&#34;&gt;==&lt;/span&gt;&amp;#39;ELEV&amp;#39; &lt;span class=&#34;p&#34;&gt;(&lt;/span&gt;&lt;span class=&#34;k&#34;&gt;shift&lt;/span&gt; &lt;span class=&#34;p&#34;&gt;&amp;amp;&lt;/span&gt; &lt;span class=&#34;k&#34;&gt;goto&lt;/span&gt; &lt;span class=&#34;nl&#34;&gt;gotPrivileges&lt;/span&gt;&lt;span class=&#34;p&#34;&gt;)&lt;/span&gt;  

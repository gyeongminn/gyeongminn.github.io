    &lt;td&gt;
      &lt;table&gt;
        &lt;tr&gt;&lt;th&gt;A&lt;/th&gt;&lt;th&gt;B&lt;/th&gt;&lt;th&gt;x&lt;/th&gt;&lt;/tr&gt;

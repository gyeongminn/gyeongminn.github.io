    &lt;th style=&#34;text-align: center; vertical-align: middle; font-size: 20px;&#34;&gt;Algebraic function&lt;/th&gt;
    &lt;th style=&#34;text-align: center; vertical-align: middle; font-size: 16px;&#34;&gt;Truth table&lt;/th&gt;
  &lt;/tr&gt;

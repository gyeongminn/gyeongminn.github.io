    &lt;/tr&gt;
    &lt;tr&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;0&lt;/td&gt;
        &lt;td style=&#34;border: 1px padding: 8px; text-align: center;&#34;&gt;1&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
